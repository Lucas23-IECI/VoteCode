PORT=5177
BASE_URL=http://127.0.0.1:5177
SESSION_SECRET=change-this-local-secret

# Google OAuth. Create credentials in Google Cloud Console and add:
# http://127.0.0.1:5177/auth/google/callback
# as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local test login. Keep false in production.
ENABLE_DEV_LOGIN=true
